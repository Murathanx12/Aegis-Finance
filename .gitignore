# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# ML models (artifacts are local/train-on-deploy, not committed)
*.pkl
*.joblib
*.h5
# crash-model provenance sidecar is paired with its (ignored) .pkl — don't commit
# one without the other, or prod gets a sidecar pointing at an absent binary.
backend/models/crash_model.meta.json

# Node
node_modules/
.next/
out/

# Environment
.env
.env.local
.env.production

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Portfolio Intelligence SQLite DB (runtime-created, not checked in)
backend/data/aegis_pi.db
backend/data/aegis_pi.db-wal
backend/data/aegis_pi.db-shm

# APScheduler job store (binary runtime state — churns on every scheduler run)
backend/data/apscheduler_jobs.db
backend/data/apscheduler_jobs.db-wal
backend/data/apscheduler_jobs.db-shm

# Auto-generated replay report (regenerated by the replay harness on test runs;
# do not track — generator-staleness bug tracked separately, see docs/V2_ROADMAP)
docs/replay_report_v1.md

# Cache
data_cache/
*.parquet
.cache/

# Logs
logs/
*.log

# Docker
docker-compose.override.yml

# Internal docs (keep local only)
docs/SESSION_LOG.md
docs/IMPROVEMENT_LOG.md
docs/GAP_ANALYSIS.md
docs/GAP_ANALYSIS_ENGINE_FRONTEND.md
docs/DEEP_RESEARCH_FINDINGS.md
docs/DEEP_RESEARCH_FINDINGS_ACADEMIC.md
docs/DEEP_RESEARCH_FINDINGS_INDUSTRY.md
docs/STRESS_TEST_RESULTS.md
docs/STRESS_TEST_PORTFOLIOS.md

# Claude Code — ignore contents (`.claude/*`, not `.claude/`: git never
# descends into a fully-excluded dir, which made the re-include dead) but
# track the session commands.
.claude/*
!.claude/commands/

# Lab autonomous-R&D scratch output — the overnight loop commits per-cycle data
# dumps (data/, data_after/, data_test/). ~2,587 files / ~7.7MB already tracked;
# this stops NEW cycles from adding more. To untrack the existing ones (working
# tree preserved, no history rewrite):
#   git rm -r --cached lab/experiments
# See docs/BACKLOG.md item H1.
lab/experiments/*/data/
lab/experiments/*/data_after/
lab/experiments/*/data_test/
lab/experiments/**/*.json

# Raw session transcript committed by mistake (space in filename, no extension).
# Untrack with: git rm --cached "docs/v2 session transcript"
docs/v2 session transcript

# Coverage artifacts
.coverage
htmlcov/

# Machine-specific MCP wiring (absolute paths)
.mcp.json
