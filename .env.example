# Required for FRED macro data (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Optional — for enhanced stock data
FINNHUB_API_KEY=
FMP_API_KEY=

# Optional — DeepSeek LLM for AI analysis (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# Backend
PORT=8000

# Persistence for paper accounts (Portfolio Intelligence). Mutable state
# (aegis_pi.db + scheduler job store) is written here. Leave unset locally
# (defaults to backend/data). On Railway, mount a persistent volume at /data
# and set AEGIS_DATA_DIR=/data so the track record survives redeploys.
# Do NOT point this at backend/data on a volume — it would shadow the baked-in
# paper_portfolios.yaml config and break lane init on boot.
# AEGIS_DATA_DIR=/data

# CORS — comma-separated allowed origins (defaults to localhost if unset)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (set to deployed backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000
