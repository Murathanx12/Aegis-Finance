# Required for FRED macro data (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Optional — for enhanced stock data
FINNHUB_API_KEY=
FMP_API_KEY=

# Optional — DeepSeek LLM for AI analysis (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=

# Backend
PORT=8000

# CORS — comma-separated allowed origins (defaults to localhost if unset)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend (set to deployed backend URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000
